{
	"name": "spotify-clone",
	"version": "0.1.0",
	"private": true,
	"packageManager": "yarn@4.6.0",
	"workspaces": [
		"apps/*"
	],
	"resolutions": {
		"mux-embed@workspace:*": "npm:mux-embed@^5.17.0"
	},
	"scripts": {
		"dev": "concurrently \"yarn:dev:frontend\" \"yarn:dev:backend\" \"yarn:dev:media\"",
		"dev:frontend": "yarn workspace frontend dev",
		"dev:backend": "yarn workspace backend start:dev",
		"dev:media": "yarn workspace media start:dev",
		"build": "yarn workspaces foreach -A run build",
		"build:frontend": "yarn workspace frontend build",
		"build:backend": "yarn workspace backend build",
		"build:media": "yarn workspace media build",
		"biome:format": "yarn biome format",
		"biome:lint": "yarn biome lint",
		"biome:check": "yarn biome check --write"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@tailwindcss/postcss": "^4.2.0",
		"concurrently": "^9.1.2",
		"wait-on": "^9.0.4"
	}
}
