{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Backend",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "yarn",
			"runtimeArgs": ["workspace", "backend", "start:debug"],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"],
			"sourceMaps": true
		},
		{
			"name": "Frontend",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "yarn",
			"runtimeArgs": ["workspace", "frontend", "dev"],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"],
			"sourceMaps": true
		},
		{
			"name": "Media",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "yarn",
			"runtimeArgs": ["workspace", "media", "start:debug"],
			"cwd": "${workspaceFolder}",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"],
			"sourceMaps": true
		}
	],
	"compounds": [
		{
			"name": "Run Monorepo",
			"configurations": ["Backend", "Frontend", "Media"],
			"stopAll": true
		}
	]
}
